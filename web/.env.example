# ─────────────────────────────────────────────────────────────
# Alexandria — variables de entorno
# Copia este archivo a `.env.local` y rellena los valores reales.
# `.env.local` está en .gitignore y NUNCA se commitea.
# ─────────────────────────────────────────────────────────────

# Supabase de DATOS de Alexandria (protocolos, etc.) — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://[project].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Supabase de AUTH (Sprint 9 — SSO contra OTRO proyecto). Si Auth y datos son el
# MISMO proyecto, repetir los valores de arriba. Si son distintos, usar los del
# proyecto externo del que se hereda la sesión.
NEXT_PUBLIC_AUTH_SUPABASE_URL=https://[auth-project].supabase.co
NEXT_PUBLIC_AUTH_SUPABASE_ANON_KEY=eyJ...
# Login del proyecto externo (redirección al hacer logout o sin sesión).
NEXT_PUBLIC_EXTERNAL_LOGIN_URL=https://otroapp.tuempresa.com/login

# Gemini AI (Google AI Studio → API key). NUNCA se expone al cliente:
# solo se usa en API Routes server-side.
GEMINI_API_KEY=AIza...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Feature Flags — cambiar a 'true' para activar integraciones reales.
# Activar de a uno y probar antes de avanzar al siguiente:
#   1) SUPABASE  2) AUTH  3) GEMINI
NEXT_PUBLIC_USE_REAL_SUPABASE=false
NEXT_PUBLIC_USE_REAL_AUTH=false
NEXT_PUBLIC_USE_REAL_GEMINI=false
