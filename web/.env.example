# ─────────────────────────────────────────────────────────────
# Alexandria — variables de entorno
# Copia este archivo a `.env.local` y rellena los valores reales.
# `.env.local` está en .gitignore y NUNCA se commitea.
# ─────────────────────────────────────────────────────────────

# Supabase de DATOS de Alexandria (protocolos, etc.) — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://[project].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# ⚠️ SECRETA — service_role key del proyecto de DATOS. SOLO servidor.
# Se usa únicamente en route handlers (p. ej. /api/auth/sync-profile) para
# escrituras privilegiadas DESPUÉS de autenticar al usuario. Ignora RLS por
# diseño, así que NUNCA debe llevar prefijo NEXT_PUBLIC_ ni exponerse al cliente.
# En Vercel: Environment Variables (Production/Preview), nunca en el bundle.
SUPABASE_DATA_SERVICE_ROLE_KEY=eyJ... # service_role, NO la anon

# Supabase de AUTH = proyecto UiX Lingo (SSO Escenario B1). Es un proyecto
# SEPARADO del de datos de arriba y NO se unifica: el auth.uid() de UiX Lingo es
# el identificador único del usuario. El handoff SSO (tokens _sso_at/_sso_rt en
# sessionStorage) se canjea con estos valores y la sesión queda en cookie.
NEXT_PUBLIC_AUTH_SUPABASE_URL=https://[uix-lingo-project].supabase.co
NEXT_PUBLIC_AUTH_SUPABASE_ANON_KEY=eyJ...
# Login del proyecto externo (redirección al hacer logout o sin sesión).
NEXT_PUBLIC_EXTERNAL_LOGIN_URL=https://otroapp.tuempresa.com/login

# Gemini AI (Google AI Studio → API key). NUNCA se expone al cliente:
# solo se usa en API Routes server-side.
GEMINI_API_KEY=AIza...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Feature Flags — cambiar a 'true' para activar integraciones reales.
# Activar de a uno y probar antes de avanzar al siguiente:
#   1) SUPABASE  2) AUTH  3) GEMINI
NEXT_PUBLIC_USE_REAL_SUPABASE=false
NEXT_PUBLIC_USE_REAL_AUTH=false
NEXT_PUBLIC_USE_REAL_GEMINI=false
